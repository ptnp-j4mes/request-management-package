{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@rm/db": ["./packages/db/src/index.ts"],
      "@rm/types": ["./packages/types/src/index.ts"],
      "@rm/utils": ["./packages/utils/src/index.ts"],
      "@rm/config": ["./packages/config/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "**/dist"]
}
